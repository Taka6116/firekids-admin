# API（バックエンド）
NEXT_PUBLIC_API_BASE_URL=https://api.firekids.jp

# Cognito（必須・ログインに使用）AWS コンソールの User Pool / アプリクライアントの「実値」を入れること。
# 未設定のままだとプレースホルダーが使われ、「User pool client placeholder... does not exist」になります。
NEXT_PUBLIC_COGNITO_USER_POOL_ID=ap-northeast-1_nxiDseEba
NEXT_PUBLIC_COGNITO_CLIENT_ID=709s7mf3vfhla9d24hi5ugrv7q
NEXT_PUBLIC_COGNITO_REGION=ap-northeast-1

# true のとき API を呼ばず src/lib/mockData.ts を返す（MSW は使わない）。UI 確認時は true 推奨。
NEXT_PUBLIC_USE_MOCK=true

# --- 結合テスト（Step 7）: `npm run verify:api` のみ使用。ブラウザでログイン後、開発者ツール等で idToken を一時的に貼る。Git にコミットしないこと。---
# INTEGRATION_ID_TOKEN=

# --- 開発専用: `npm run dev` 時のみログイン画面が自動サインインを試みます（本番 build では API 無効）---
# 実値は .env.local にのみ書いてください（Git にコミットしないこと）。
AUTH_EMAIL=your-email@example.com
AUTH_PASSWORD=your-password
